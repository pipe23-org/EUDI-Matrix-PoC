+/**
+ * Returns true if the given text looks like an international phone number (E.164 format).
+ * Strips spaces and dashes before checking. Requires 7-15 digits after the leading +.
+ */
+function looksLikePhoneNumber(text: string): boolean {
+    return /^\+[0-9]{7,15}$/.test(text.replace(/[\s\-]/g, ""));
+}
