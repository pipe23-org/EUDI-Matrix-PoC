+                if (!token) return;
+
+                if (term !== this.state.filterText) return;
+
+                // Strip spaces/dashes and leading '+' for E.164 msisdn format
+                const msisdn = term.replace(/[\s\-]/g, "").substring(1);
+                const lookup = await MatrixClientPeg.safeGet().lookupThreePid("msisdn", msisdn, token);
