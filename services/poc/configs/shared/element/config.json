  "default_country_code": "FI",
  "disable_guests": true,
  "disable_3pid_login": true,
  "setting_defaults": {
    "UIFeature.identityServer": true,
    "feature_disable_call_per_sender_encryption": true
  },
  "features": {
    "feature_dehydration": false
  },
  "force_device_key_backup": false,
  "show_labs_settings": false,
  "e2ee": {
    "default": false,
    "force_disable": true,
    "secure_backup_required": false
  }
