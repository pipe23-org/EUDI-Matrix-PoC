{
  "default_server_config": {
    "m.homeserver": {
      "base_url": "https://${SYNAPSE_HOST}",
      "server_name": "${SYNAPSE_HOST}"
    },
    "m.identity_server": {
      "base_url": "https://${PHONEBOOK_HOST}"
    },
    "m.authentication": {
      "issuer": "https://${AUTH_HOST}/"
    }
  },
  "oidc_static_clients": {
    "https://${AUTH_HOST}/": {
      "client_id": "0000000000000000000WEBAPPS"
    }
